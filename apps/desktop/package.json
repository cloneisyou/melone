{
  "name": "melone-desktop",
  "version": "0.1.1",
  "private": true,
  "description": "Melone 데스크톱 셸 — 수집 서비스 상태와 MCP 연동을 담는 Electron 트레이 앱",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node -e \"require('electron')\" && electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --publish never",
    "dist:mac": "electron-vite build && electron-builder --mac --arm64 --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "posthog-js": "^1.391.3"
  }
}
