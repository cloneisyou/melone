# Melone normally launches without any environment variables.
# Copy only the section you need into .env.local or your shell profile.

## Local development isolation

# Optional. Defaults to ~/Library/Application Support/Melone.
# MELONE_HOME=/tmp/melone-dev

# Optional. Desktop service Python resolver defaults to the app/dev venv, then PATH.
# MELONE_PYTHON=/absolute/path/to/python3


## Screen Text Search developer overrides

# Product enablement lives in the app setting and is off by default.
# Use these only to override local smoke tests without changing settings.json.
# MELONE_SCREENSHOT_COLLECTOR_ENABLED=1
# MELONE_SCREEN_SEARCH_WORKERS_ENABLED=1

# Keep original Screen Text Search PNGs for local debugging. Defaults to false.
# MELONE_SCREEN_TEXT_RETAIN_SCREENSHOTS=1

# Optional throughput/backpressure tuning.
# MELONE_SCREEN_SEARCH_MAX_JOBS_PER_TICK=2
# MELONE_SCREEN_SEARCH_RETRY_BACKOFF_SECONDS=60
# MELONE_SCREEN_SEARCH_HIGH_BACKLOG_THRESHOLD=20
# MELONE_SCREEN_SEARCH_VERY_HIGH_BACKLOG_THRESHOLD=100


## Optional semantic Screen Text Search rollout

# Requires installing the service semantic extra and accepting access to
# google/embeddinggemma-300m in Hugging Face. Defaults to disabled; when disabled
# or unavailable, search falls back to label/URL, BM25 screen text, and PageRank.
# MELONE_SEMANTIC_SEARCH_ENABLED=false
# MELONE_EMBEDDING_MODEL=google/embeddinggemma-300m
# MELONE_EMBEDDING_DIMENSION=256
# MELONE_EMBEDDING_BATCH_SIZE=16
# MELONE_SEMANTIC_SEARCH_CANDIDATE_LIMIT=50


## OCR recognition languages (default Apple Vision backend)

# Comma-separated recognition languages for the default Apple Vision backend.
# A mismatch with the screen content returns empty/garbled text. Default is
# ko-KR,en-US. Use "auto" to let Vision auto-detect.
# MELONE_OCR_LANGUAGES=ko-KR,en-US

# Apple Vision language correction. Off by default because it autocorrects
# on-screen code/identifiers/paths. Set true for prose-heavy content.
# MELONE_OCR_LANGUAGE_CORRECTION=false


## Advanced local OCR backend

# The product default is Apple Vision and does not need a local model server.
# Set these only when intentionally testing a local OpenAI-compatible backend.
# MELONE_OCR_PROVIDER=local_vllm
# MELONE_OCR_ENDPOINT=http://127.0.0.1:8000/v1
# MELONE_OCR_MODEL=lightonai/LightOnOCR-2-1B
# MELONE_OCR_TIMEOUT_SECONDS=120
# MELONE_OCR_MAX_TOKENS=4096


## Desktop integrations

# Optional desktop update banner simulation for development.
# MELONE_FAKE_UPDATE=1
